{
  "name": "fta-time-tracker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --port 4200",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "npm run build:prod && node deploy-non-interactive.js",
    "deploy:hosting": "npm run build:prod && cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 firebase deploy --only hosting",
    "deploy:firestore": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 firebase deploy --only firestore",
    "firebase:deploy": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 firebase deploy",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/fire": "^18.0.1",
    "@angular/forms": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "firebase": "^10.14.1",
    "jspdf": "^2.5.0",
    "jspdf-autotable": "^3.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/jasmine": "~5.1.0",
    "cross-env": "^7.0.0",
    "firebase-tools": "^13.0.0",
    "google-auth-library": "^10.5.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
